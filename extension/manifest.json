{
  "manifest_version": 3,
  "name": "bytesize",
  "version": "1.0.0",
  "description": "Shorten the current page URL instantly.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": ["activeTab", "clipboardWrite"],
  "host_permissions": ["<all_urls>"]
}
